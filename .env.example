# Cloudflare Worker sponsor redirect secrets
PARTNER_REDIRECT_BASE_URL=
PARTNER_REDIRECT_SOURCE=opentoolskit
# Backward-compatible legacy env name for one release:
# ZEYDOO_BASE_URL=
# ZEYDOO_SOURCE=opentoolskit
SPONSOR_FALLBACK_URL=https://www.opentoolskit.com/en/contact

# Controlled download gate. Set to false to keep the soft post-result drawer only.
NEXT_PUBLIC_OTK_HARD_GATE_ENABLED=true

# Optional real inline Adsterra display/banner zones.
# These are NOT Popunder, Social Bar, Native Banner, or Zeydoo smartlink URLs.
# Create separate Adsterra Banner/Display zones for each page surface, then paste the script src
# and the matching atOptions JSON from the Adsterra ad code.
NEXT_PUBLIC_ADSTERRA_LEADERBOARD_SCRIPT_SRC=https://www.highperformanceformat.com/0bdd950b739b904ab9f0044bfa63042a/invoke.js
NEXT_PUBLIC_ADSTERRA_LEADERBOARD_AT_OPTIONS={"key":"0bdd950b739b904ab9f0044bfa63042a","format":"iframe","height":90,"width":728,"params":{}}
