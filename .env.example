# Cloudflare Worker sponsor redirect secrets
PARTNER_REDIRECT_BASE_URL=
PARTNER_REDIRECT_SOURCE=opentoolskit
# Backward-compatible legacy env name for one release:
# ZEYDOO_BASE_URL=
# ZEYDOO_SOURCE=opentoolskit
SPONSOR_FALLBACK_URL=https://www.opentoolskit.com/en/contact/
NEXT_PUBLIC_SUPPORT_EMAIL=support@opentoolskit.com

# Temporary Google AdSense review mode. Defaults to true in code for this review pass.
# Set to false after approval to restore Adsterra/Zeydoo monetization surfaces.
NEXT_PUBLIC_ADSENSE_REVIEW_MODE=true
NEXT_PUBLIC_GOOGLE_ADSENSE_VERIFICATION_ENABLED=true
NEXT_PUBLIC_THIRD_PARTY_MONETIZATION_ENABLED=false

# Controlled download gate. Keep false during AdSense review.
NEXT_PUBLIC_OTK_HARD_GATE_ENABLED=false

# Optional real inline Adsterra display/banner zones.
# These are NOT Popunder, Social Bar, Native Banner, or Zeydoo smartlink URLs.
# Create separate Adsterra Banner/Display zones for each page surface, then paste the script src
# and the matching atOptions JSON from the Adsterra ad code.
# Keep deployment-specific zone URLs/keys in Cloudflare, not committed source.
NEXT_PUBLIC_ADSTERRA_LEADERBOARD_SCRIPT_SRC=
NEXT_PUBLIC_ADSTERRA_LEADERBOARD_AT_OPTIONS={"key":"REPLACE_WITH_LEADERBOARD_ZONE_KEY","format":"iframe","height":90,"width":728,"params":{}}
NEXT_PUBLIC_ADSTERRA_RECTANGLE_SCRIPT_SRC=
NEXT_PUBLIC_ADSTERRA_RECTANGLE_AT_OPTIONS={"key":"REPLACE_WITH_RECTANGLE_ZONE_KEY","format":"iframe","height":250,"width":300,"params":{}}
NEXT_PUBLIC_ADSTERRA_LEFT_RAIL_SCRIPT_SRC=
NEXT_PUBLIC_ADSTERRA_LEFT_RAIL_AT_OPTIONS={"key":"REPLACE_WITH_LEFT_RAIL_ZONE_KEY","format":"iframe","height":600,"width":160,"params":{}}
NEXT_PUBLIC_ADSTERRA_RIGHT_RAIL_SCRIPT_SRC=
NEXT_PUBLIC_ADSTERRA_RIGHT_RAIL_AT_OPTIONS={"key":"REPLACE_WITH_RIGHT_RAIL_ZONE_KEY","format":"iframe","height":300,"width":160,"params":{}}
NEXT_PUBLIC_ADSTERRA_MOBILE_STICKY_SCRIPT_SRC=
NEXT_PUBLIC_ADSTERRA_MOBILE_STICKY_AT_OPTIONS={"key":"REPLACE_WITH_MOBILE_STICKY_ZONE_KEY","format":"iframe","height":50,"width":320,"params":{}}
NEXT_PUBLIC_ADSTERRA_468X60_SCRIPT_SRC=
NEXT_PUBLIC_ADSTERRA_468X60_AT_OPTIONS={"key":"REPLACE_WITH_468X60_ZONE_KEY","format":"iframe","height":60,"width":468,"params":{}}

# Optional non-display Adsterra zones. Leave blank during AdSense review.
NEXT_PUBLIC_ADSTERRA_NATIVE_SCRIPT_SRC=
NEXT_PUBLIC_ADSTERRA_NATIVE_CONTAINER_ID=
NEXT_PUBLIC_ADSTERRA_POPUNDER_SCRIPT_SRC=
NEXT_PUBLIC_ADSTERRA_SOCIAL_BAR_SCRIPT_SRC=
