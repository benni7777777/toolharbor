# Cloudflare Worker sponsor redirect secrets
PARTNER_REDIRECT_BASE_URL=
PARTNER_REDIRECT_SOURCE=opentoolskit
# Backward-compatible legacy env name for one release:
# ZEYDOO_BASE_URL=
# ZEYDOO_SOURCE=opentoolskit
SPONSOR_FALLBACK_URL=https://www.opentoolskit.com/en/contact

# Default production monetization path is the soft post-result drawer.
# Set to true only after live ad runtime verification is complete.
NEXT_PUBLIC_OTK_HARD_GATE_ENABLED=false

# Optional real inline Adsterra display/banner zones.
# These are NOT Popunder, Social Bar, Native Banner, or Zeydoo smartlink URLs.
# Create separate Adsterra Banner/Display zones for each page surface, then paste the script src
# and the matching atOptions JSON from the Adsterra ad code.
NEXT_PUBLIC_ADSTERRA_LEADERBOARD_SCRIPT_SRC=
NEXT_PUBLIC_ADSTERRA_LEADERBOARD_AT_OPTIONS=
NEXT_PUBLIC_ADSTERRA_RECTANGLE_SCRIPT_SRC=
NEXT_PUBLIC_ADSTERRA_RECTANGLE_AT_OPTIONS=
NEXT_PUBLIC_ADSTERRA_LEFT_RAIL_SCRIPT_SRC=
NEXT_PUBLIC_ADSTERRA_LEFT_RAIL_AT_OPTIONS=
NEXT_PUBLIC_ADSTERRA_RIGHT_RAIL_SCRIPT_SRC=
NEXT_PUBLIC_ADSTERRA_RIGHT_RAIL_AT_OPTIONS=
NEXT_PUBLIC_ADSTERRA_MOBILE_STICKY_SCRIPT_SRC=
NEXT_PUBLIC_ADSTERRA_MOBILE_STICKY_AT_OPTIONS=
